---
export interface Props {
  title: string;
  excerpt: string;
  tags: string[];
  slug: string;
  date?: string;
}

const { title, excerpt, tags, slug, date } = Astro.props;
---

<a href={`/blog/${slug}`} class="article-row">
  <div class="row-main">
    <h3>{title}</h3>
    <p class="excerpt">{excerpt}</p>
    <div class="row-meta">
      {date && <span class="date">{date}</span>}
      {tags.map(tag => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  </div>
  <span class="arrow" aria-hidden="true">→</span>
</a>

<style>
  .article-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 18px 4px;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--border-color);
    transition: padding-left 0.2s ease, border-color 0.2s ease;
  }

  .article-row:first-child {
    border-top: 1px solid var(--border-color);
  }

  .article-row:hover {
    padding-left: 10px;
    border-color: var(--accent-color);
  }

  .article-row:hover .arrow {
    transform: translateX(4px);
    color: var(--accent-color);
  }

  .row-main h3 {
    font-size: 1.15rem;
    line-height: 1.4;
    margin: 0 0 6px;
    color: var(--heading-color);
  }

  .excerpt {
    font-size: 0.9rem;
    color: var(--text-color);
    opacity: 0.75;
    margin: 0 0 8px;
    /* clamp so long excerpts don't blow up row height */
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .row-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .date {
    font-size: 0.8rem;
    opacity: 0.6;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 2px 8px;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    color: var(--text-color);
    opacity: 0.8;
  }

  .arrow {
    flex-shrink: 0;
    font-size: 1.2rem;
    color: var(--border-color);
    transition: transform 0.2s ease, color 0.2s ease;
  }

  @media (max-width: 600px) {
    .article-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
    .arrow {
      display: none;
    }
  }
</style>